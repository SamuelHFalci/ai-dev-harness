#!/usr/bin/env bash

set -euo pipefail

# Template root: clone location by default, or override if the binary lives elsewhere.
if [[ -n "${AI_DEV_HARNESS_ROOT:-}" ]]; then
  HARNESS_ROOT="${AI_DEV_HARNESS_ROOT%/}"
else
  _SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  HARNESS_ROOT="$(cd "$_SCRIPT_DIR/.." && pwd)"
fi

COMMAND="${1:-}"

function ensure_harness_root() {
  if [ ! -d "$HARNESS_ROOT/templates/ai-harness" ]; then
    echo "Error: could not find templates/ai-harness under HARNESS_ROOT: $HARNESS_ROOT" >&2
    echo "Set AI_DEV_HARNESS_ROOT to the cloned ai-dev-harness repository if needed." >&2
    exit 1
  fi
}

function append_gitignore_harness() {
  local gi=".gitignore"
  touch "$gi"
  local mark="# AI Dev Harness (local consultant tooling - do not commit)"
  if ! grep -Fxq "$mark" "$gi" 2>/dev/null; then
    echo "" >> "$gi"
    echo "$mark" >> "$gi"
  fi
  grep -Fxq "/.ai-harness/" "$gi" 2>/dev/null || echo "/.ai-harness/" >> "$gi"
  grep -Fxq ".cursor/rules/ai-dev-harness.mdc" "$gi" 2>/dev/null || echo ".cursor/rules/ai-dev-harness.mdc" >> "$gi"
  grep -Fxq ".cursor/rules/architecture-rules.mdc" "$gi" 2>/dev/null || echo ".cursor/rules/architecture-rules.mdc" >> "$gi"
}

function init_harness() {
  local PROFILE="${1:-application}"
  local FORCE="${2:-false}"

  ensure_harness_root

  echo "Initializing AI Dev Harness (profile: ${PROFILE})..."

  if [ -d .ai-harness ]; then
    if [ "$FORCE" != "true" ]; then
      echo "Error: .ai-harness/ already exists." >&2
      echo "Re-run with 'ai-harness init ... --force' to replace it with a fresh template copy." >&2
      echo "Warning: --force removes local harness state, docs, runtime notes, and architecture files." >&2
      exit 1
    fi
    echo "Warning: replacing existing .ai-harness/ with a fresh copy from templates."
    rm -rf .ai-harness
  fi
  mkdir -p .ai-harness
  cp -R "$HARNESS_ROOT/templates/ai-harness/." .ai-harness/
  mkdir -p .ai-harness/runtime
  mkdir -p .ai-harness/architecture

  printf '%s\n' "$PROFILE" > .ai-harness/profile

  if [ "$PROFILE" = "devops" ]; then
    mkdir -p .ai-harness/prompts .ai-harness/docs
    cp "$HARNESS_ROOT/templates/profiles/devops/prompts/run-devops-cycle.md" .ai-harness/prompts/
    cp "$HARNESS_ROOT/templates/profiles/devops/docs/DEVOPS-WORKFLOW.md" .ai-harness/docs/
  fi

  mkdir -p .cursor/rules
  local here
  here="$(pwd)"
  if [ -e "$here/.cursor/rules/ai-dev-harness.mdc" ] && [ ! -L "$here/.cursor/rules/ai-dev-harness.mdc" ]; then
    echo "Warning: .cursor/rules/ai-dev-harness.mdc exists and is not a symlink; leaving it unchanged."
    echo "         Point it at .ai-harness/cursor-rule.mdc or remove the file and re-run init."
  else
    rm -f "$here/.cursor/rules/ai-dev-harness.mdc"
    ln -sf ../../.ai-harness/cursor-rule.mdc "$here/.cursor/rules/ai-dev-harness.mdc"
  fi

  if [ -e "$here/.cursor/rules/architecture-rules.mdc" ] && [ ! -L "$here/.cursor/rules/architecture-rules.mdc" ]; then
    echo "Warning: .cursor/rules/architecture-rules.mdc exists and is not a symlink; leaving it unchanged."
    echo "         For consultant-local rules, remove it and re-run init, or symlink to .ai-harness/architecture-rules.mdc"
  else
    rm -f "$here/.cursor/rules/architecture-rules.mdc"
    ln -sf ../../.ai-harness/architecture-rules.mdc "$here/.cursor/rules/architecture-rules.mdc"
  fi

  mkdir -p specs
  if [ -d "$HARNESS_ROOT/templates/specs" ]; then
    cp -R "$HARNESS_ROOT/templates/specs/." specs/
  fi

  append_gitignore_harness

  echo "AI Dev Harness initialized."
  echo ""
  echo "Harness + local architecture pack: .ai-harness/ (gitignored by init)"
  echo "Cursor symlinks:"
  echo "  .cursor/rules/ai-dev-harness.mdc   -> .ai-harness/cursor-rule.mdc"
  echo "  .cursor/rules/architecture-rules.mdc -> .ai-harness/architecture-rules.mdc"
  echo "Deep-dive arch markdown: .ai-harness/architecture/"
  echo "Harness input docs (local): .ai-harness/docs/00-project-context|10-feature-requests|20-change-requests/"
  echo ""
  echo "Next steps:"
  echo ""
  echo "1. Add project context docs to:"
  echo "   .ai-harness/docs/00-project-context/"
  echo ""
  echo "2. Add feature requests to:"
  echo "   .ai-harness/docs/10-feature-requests/"
  echo ""
  echo "3. Open Cursor Agent and run:"
  echo ""
  if [ "$PROFILE" = "devops" ]; then
    echo "   Read and execute .ai-harness/prompts/run-devops-cycle.md"
    echo ""
    echo "   (See .ai-harness/docs/DEVOPS-WORKFLOW.md for how this profile maps specs to IaC.)"
  else
    echo "   # For most tasks (features, fixes, small refactors):"
    echo "   Read and execute .ai-harness/prompts/run-autonomous-cycle-lite.md"
    echo ""
    echo "   # For architecture changes or large cross-cutting refactors:"
    echo "   Read and execute .ai-harness/prompts/run-autonomous-cycle-deep.md"
    echo ""
    echo "   # To verify existing implementation without replanning:"
    echo "   Read and execute .ai-harness/prompts/run-validation-only.md"
    echo ""
    echo "   # To translate a spec/doc directly into code:"
    echo "   Read and execute .ai-harness/prompts/run-docs-to-implementation.md"
    echo ""
    echo "   # To resume an interrupted session:"
    echo "   Read and execute .ai-harness/prompts/run-resume.md"
    echo ""
    echo "   # Architecture-rules examples (for bootstrap reference):"
    echo "   .ai-harness/examples/architecture-rules-nestjs.mdc"
    echo "   .ai-harness/examples/architecture-rules-python.mdc"
    echo ""
    echo "   (Legacy: run-autonomous-cycle.md still available for reference.)"
  fi
}

function upgrade_harness() {
  ensure_harness_root

  if [ ! -d .ai-harness ]; then
    echo "Error: .ai-harness/ not found. Run 'ai-harness init' first." >&2
    exit 1
  fi

  local UPDATE_CURSOR="false"
  local SKIP_MODES="false"

  while [ $# -gt 0 ]; do
    case "$1" in
      --update-cursor-rule) UPDATE_CURSOR="true" ;;
      --skip-modes)         SKIP_MODES="true" ;;
      *)
        echo "Unknown upgrade option: $1" >&2
        echo "Usage: ai-harness upgrade [--update-cursor-rule] [--skip-modes]" >&2
        exit 1
        ;;
    esac
    shift
  done

  local copied=0
  local skipped=0

  echo "Upgrading AI Dev Harness..."
  echo ""

  # ── 1. New runner prompts — add only if missing ──────────────────────────
  local new_prompts=(
    "prompts/run-autonomous-cycle-lite.md"
    "prompts/run-autonomous-cycle-deep.md"
    "prompts/run-validation-only.md"
    "prompts/run-docs-to-implementation.md"
    "prompts/run-resume.md"
    "prompts/modes/doc-sync-mode.md"
  )
  for f in "${new_prompts[@]}"; do
    if [ ! -f ".ai-harness/$f" ]; then
      cp "$HARNESS_ROOT/templates/ai-harness/$f" ".ai-harness/$f"
      echo "  added:   .ai-harness/$f"
      copied=$((copied + 1))
    else
      echo "  exists:  .ai-harness/$f (skipped)"
      skipped=$((skipped + 1))
    fi
  done

  # ── 2. context-index.md — always refresh (map file, not user data) ────────
  cp "$HARNESS_ROOT/templates/ai-harness/context-index.md" ".ai-harness/context-index.md"
  echo "  updated: .ai-harness/context-index.md"
  copied=$((copied + 1))

  # ── 3. New state files — add only if missing (never overwrite live state) ─
  local new_state=(
    "state/current-task.md"
    "state/context-cache.md"
    "state/decisions.md"
  )
  for f in "${new_state[@]}"; do
    if [ ! -f ".ai-harness/$f" ]; then
      cp "$HARNESS_ROOT/templates/ai-harness/$f" ".ai-harness/$f"
      echo "  added:   .ai-harness/$f"
      copied=$((copied + 1))
    else
      echo "  exists:  .ai-harness/$f (skipped)"
      skipped=$((skipped + 1))
    fi
  done

  # ── 4. Mode files — always update (template content, not user data) ───────
  local mode_files=(
    "prompts/modes/adoption-mode.md"
    "prompts/modes/discovery-mode.md"
    "prompts/modes/spec-reviewer-mode.md"
    "prompts/modes/speckit-mode.md"
    "prompts/modes/plan-reviewer-mode.md"
    "prompts/modes/task-reviewer-mode.md"
    "prompts/modes/implementer-mode.md"
    "prompts/modes/qa-mode.md"
    "prompts/modes/code-review-mode.md"
  )
  if [ "$SKIP_MODES" = "false" ]; then
    for f in "${mode_files[@]}"; do
      cp "$HARNESS_ROOT/templates/ai-harness/$f" ".ai-harness/$f"
      echo "  updated: .ai-harness/$f"
      copied=$((copied + 1))
    done
  else
    echo "  skipped: prompts/modes/ (--skip-modes set)"
    skipped=$((skipped + ${#mode_files[@]}))
  fi

  # ── 5. Examples — always refresh (reference files, not user data) ─────────
  mkdir -p ".ai-harness/examples"
  cp "$HARNESS_ROOT/templates/ai-harness/examples/architecture-rules-nestjs.mdc" ".ai-harness/examples/"
  cp "$HARNESS_ROOT/templates/ai-harness/examples/architecture-rules-python.mdc" ".ai-harness/examples/"
  echo "  updated: .ai-harness/examples/"
  copied=$((copied + 1))

  # ── 6. cursor-rule.mdc — inject bootstrap line if missing (safe patch) ────
  local cursor_rule=".ai-harness/cursor-rule.mdc"
  local bootstrap_line="Bootstrap: read \`.ai-harness/context-index.md\` first before opening any doc or architecture file. Choose the mode prompt from there — prefer \`run-autonomous-cycle-lite.md\` for features and fixes."

  if [ "$UPDATE_CURSOR" = "true" ]; then
    cp "$cursor_rule" "${cursor_rule}.bak"
    cp "$HARNESS_ROOT/templates/ai-harness/cursor-rule.mdc" "$cursor_rule"
    echo "  replaced: $cursor_rule (backup: cursor-rule.mdc.bak)"
    copied=$((copied + 1))
  elif ! grep -q "^Bootstrap:" "$cursor_rule" 2>/dev/null; then
    # Inject bootstrap line after the closing --- of the frontmatter
    awk -v line="$bootstrap_line" '
      BEGIN { count=0; done=0 }
      /^---$/ { count++; print; if (count==2 && !done) { print ""; print line; done=1 } next }
      { print }
    ' "$cursor_rule" > "${cursor_rule}.tmp" && mv "${cursor_rule}.tmp" "$cursor_rule"
    echo "  patched: $cursor_rule (Bootstrap line injected)"
    copied=$((copied + 1))
  else
    echo "  ok:      $cursor_rule (Bootstrap line already present)"
  fi

  # ── 7. profile — create if missing ───────────────────────────────────────
  if [ ! -f ".ai-harness/profile" ]; then
    echo "application" > ".ai-harness/profile"
    echo "  added:   .ai-harness/profile (defaulting to 'application')"
    copied=$((copied + 1))
  else
    echo "  ok:      .ai-harness/profile ($(cat .ai-harness/profile))"
  fi

  echo ""
  echo "Upgrade complete: $copied file(s) added/updated, $skipped skipped."
  echo ""
  echo "Never touched: docs/, architecture/, architecture-rules.mdc,"
  echo "               state/project-state.json, spec-queue.json, run-log.md, specs/"
  echo ""
  echo "Prompts:"
  echo "  run-autonomous-cycle-lite.md    default — features and fixes"
  echo "  run-autonomous-cycle-deep.md    architecture changes and large refactors"
  echo "  run-resume.md                   resume an interrupted session"
  echo "  run-validation-only.md          verify without replanning"
  echo "  run-docs-to-implementation.md   approved spec/doc → code"
}

function status_harness() {
  ensure_harness_root

  if [ ! -f .ai-harness/state/project-state.json ]; then
    echo "Harness not initialized (.ai-harness/state/project-state.json missing)."
    exit 1
  fi

  cat .ai-harness/state/project-state.json
}

function print_cli_prompt() {
  ensure_harness_root
  local name="$1"
  local file="$HARNESS_ROOT/templates/cli-prompts/${name}.txt"
  if [ ! -f "$file" ]; then
    echo "Error: missing prompt file: $file" >&2
    exit 1
  fi
  cat "$file"
}

function doctor_harness() {
  ensure_harness_root

  local failed=0
  local required_paths=(
    "$HARNESS_ROOT/bin/ai-harness"
    "$HARNESS_ROOT/scripts/install.sh"
    "$HARNESS_ROOT/templates/ai-harness/cursor-rule.mdc"
    "$HARNESS_ROOT/templates/ai-harness/architecture-rules.mdc"
    "$HARNESS_ROOT/templates/ai-harness/context-index.md"
    "$HARNESS_ROOT/templates/ai-harness/prompts/run-autonomous-cycle.md"
    "$HARNESS_ROOT/templates/ai-harness/prompts/run-autonomous-cycle-lite.md"
    "$HARNESS_ROOT/templates/ai-harness/prompts/run-autonomous-cycle-deep.md"
    "$HARNESS_ROOT/templates/ai-harness/prompts/run-resume.md"
    "$HARNESS_ROOT/templates/ai-harness/prompts/run-validation-only.md"
    "$HARNESS_ROOT/templates/ai-harness/prompts/run-docs-to-implementation.md"
    "$HARNESS_ROOT/templates/ai-harness/prompts/modes/doc-sync-mode.md"
    "$HARNESS_ROOT/templates/ai-harness/examples/architecture-rules-nestjs.mdc"
    "$HARNESS_ROOT/templates/ai-harness/examples/architecture-rules-python.mdc"
    "$HARNESS_ROOT/templates/ai-harness/state/project-state.json"
    "$HARNESS_ROOT/templates/ai-harness/state/spec-queue.json"
    "$HARNESS_ROOT/templates/ai-harness/state/current-task.md"
    "$HARNESS_ROOT/templates/ai-harness/state/context-cache.md"
    "$HARNESS_ROOT/templates/ai-harness/state/decisions.md"
    "$HARNESS_ROOT/templates/specs"
    "$HARNESS_ROOT/templates/profiles/devops/prompts/run-devops-cycle.md"
    "$HARNESS_ROOT/templates/profiles/devops/docs/DEVOPS-WORKFLOW.md"
    "$HARNESS_ROOT/templates/cli-prompts/architecture-rules.txt"
    "$HARNESS_ROOT/templates/cli-prompts/spec-decomposition.txt"
  )

  for path in "${required_paths[@]}"; do
    if [ ! -e "$path" ]; then
      echo "Missing: $path" >&2
      failed=1
    fi
  done

  if [ "$failed" -ne 0 ]; then
    echo "AI Dev Harness doctor failed." >&2
    exit 1
  fi

  echo "AI Dev Harness doctor passed."
}

case "$COMMAND" in
  init)
    shift || true
    PROFILE="application"
    FORCE="false"
    while [ $# -gt 0 ]; do
      case "$1" in
        --force)
          FORCE="true"
          ;;
        devops)
          PROFILE="devops"
          ;;
        app|application)
          PROFILE="application"
          ;;
        *)
          echo "Unknown init option: $1" >&2
          echo "Usage: ai-harness init [application|devops] [--force]" >&2
          exit 1
          ;;
      esac
      shift
    done
    init_harness "$PROFILE" "$FORCE"
    ;;
  upgrade)
    shift || true
    upgrade_harness "$@"
    ;;
  status)
    status_harness
    ;;
  doctor)
    doctor_harness
    ;;
  architecture-rules)
    print_cli_prompt "architecture-rules"
    ;;
  spec-decomposition)
    print_cli_prompt "spec-decomposition"
    ;;
  -h|--help|help|"")
    echo "Usage:"
    echo "  ai-harness init [application|devops] [--force]"
    echo "  ai-harness upgrade [--update-cursor-rule] [--skip-modes]"
    echo "  ai-harness status"
    echo "  ai-harness doctor"
    echo "  ai-harness architecture-rules   # print Cursor Agent prompt (stdout)"
    echo "  ai-harness spec-decomposition   # print Cursor Agent prompt (stdout)"
    ;;
  *)
    echo "Unknown command: $COMMAND" >&2
    echo "" >&2
    echo "Usage:"
    echo "  ai-harness init [application|devops] [--force]"
    echo "  ai-harness upgrade [--update-cursor-rule]"
    echo "  ai-harness status"
    echo "  ai-harness doctor"
    echo "  ai-harness architecture-rules"
    echo "  ai-harness spec-decomposition"
    exit 1
    ;;
esac
