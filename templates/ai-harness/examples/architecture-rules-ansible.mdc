## ansible.cfg conventions

```ini
[defaults]
inventory = ./inventory         # or ./inventories/<env>/hosts
stdout_callback = yaml
retry_files_enabled = False
interpreter_python = auto_silent
roles_path = ./roles
collections_paths = ./collections
host_key_checking = True        # False only in dev/lab — never in prod

# Multi-env vault (one identity per environment):
# vault_identity_list = prod@~/.vault/prod_pass, staging@~/.vault/staging_pass

[privilege_escalation]
become = True
become_method = sudo
become_ask_pass = False         # provide via -K or vault

[ssh_connection]
pipelining = True               # requires: Defaults !requiretty in /etc/sudoers
```

